# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/medi_store

# JWT
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production

# Base URLs
APP_BASE_URL=http://localhost:5000
CLIENT_PAYMENT_SUCCESS_URL=http://localhost:3000/payment-success
CLIENT_PAYMENT_FAILED_URL=http://localhost:3000/payment-failed
CLIENT_PAYMENT_CANCEL_URL=http://localhost:3000/payment-failed

# SSLCommerz Payment Gateway
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_SESSION_API_URL=https://sandbox.sslcommerz.com/gwprocess/v4/api.php
SSLCOMMERZ_VALIDATION_API_URL=https://sandbox.sslcommerz.com/validator/api/validationserverAPI.php

# For Production (uncomment and update):
# SSLCOMMERZ_SESSION_API_URL=https://securepay.sslcommerz.com/gwprocess/v4/api.php
# SSLCOMMERZ_VALIDATION_API_URL=https://securepay.sslcommerz.com/validator/api/validationserverAPI.php
